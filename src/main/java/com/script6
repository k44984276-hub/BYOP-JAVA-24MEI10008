package com.taskmanager;

import com.taskmanager.model.Task;
import com.taskmanager.service.TaskService;
import com.taskmanager.utils.TaskStatus;
import org.junit.jupiter.api.*;
import static org.junit.jupiter.api.Assertions.*;

public class TaskServiceTest {
    private TaskService taskService;

    @BeforeEach
    void setUp() {
        taskService = new TaskService();
    }

    @Test
    void testCreateTask() {
        Task task = taskService.createTask("Test Task", "Test Description");
        assertNotNull(task);
        assertEquals("Test Task", task.getTitle());
        assertEquals("Test Description", task.getDescription());
        assertEquals(TaskStatus.PENDING, task.getStatus());
    }

    @Test
    void testGetAllTasks() {
        taskService.createTask("Task 1", "Desc 1");
        taskService.createTask("Task 2", "Desc 2");
        assertEquals(2, taskService.getAllTasks().size());
    }

    @Test
    void testUpdateTaskStatus() {
        Task task = taskService.createTask("Test", "Desc");
        assertTrue(taskService.updateTaskStatus(task.getId(), TaskStatus.IN_PROGRESS));
        assertEquals(TaskStatus.IN_PROGRESS, task.getStatus());
    }

    @Test
    void testDeleteTask() {
        Task task = taskService.createTask("Test", "Desc");
        assertTrue(taskService.deleteTask(task.getId()));
        assertEquals(0, taskService.getAllTasks().size());
    }

    @Test
    void testSearchTasks() {
        taskService.createTask("Shopping", "Buy groceries");
        taskService.createTask("Coding", "Write Java code");
        
        assertEquals(1, taskService.searchTasks("shopping").size());
        assertEquals(1, taskService.searchTasks("Java").size());
        assertEquals(0, taskService.searchTasks("nonexistent").size());
    }
}
